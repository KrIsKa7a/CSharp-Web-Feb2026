@{
    ViewData["Title"] = "500 Internal Server Error";
}

<div class="container text-center py-5">
    <div class="mb-4">
        <i class="bi bi-x-octagon display-1" style="color: #e53935;"></i>
    </div>
    <h1 class="display-4 mb-3" style="color: #e53935;">500 Internal Server Error</h1>
    <p class="lead mb-4">
        Something went wrong on our end.<br />
        Please try again later.
    </p>
    <a href="@(Url.Action("Index", "Home"))" class="btn btn-primary btn-lg">
        <i class="bi bi-house-door"></i> Back to Home
    </a>
</div>