@model MoviesAllIndexViewModel

@{
    ViewData["Title"] = "All Movies";
    int endPageIndex = Math.Min((Model.StartPageIndex + Model.ShowingPages), Model.TotalPages);
}

@section Styles {
    <link rel="stylesheet" href="~/css/user.css">
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="text-light fw-bold">Explore Movies</h1>
        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary fw-bold">
            <i class="bi bi-arrow-left"></i> Back to Home Page
        </a>
    </div>
    
    <div class="row mt-4 mb-4 align-items-center">
        <div class="col-md-6 mb-2 mb-md-0">
            <form asp-controller="Movie" asp-action="Index" method="get" class="mb-0 d-flex">
                <div class="input-group">
                    <input asp-for="SearchQuery"
                           type="text"
                           class="form-control"
                           placeholder="Search by title..."/>
                    
                    @if (!string.IsNullOrEmpty(Model.SearchQuery))
                    {
                        <a href="@Url.Action("Index", "Movie")" class="btn btn-outline-secondary" title="Clear search">
                            <i class="bi bi-x-lg"></i>
                        </a>
                    }

                    <button type="submit" class="btn btn-primary">Search</button>
                </div>
            </form>
        </div>
        <div class="col-md-6 text-md-end">
            <nav aria-label="Page navigation example">
                <ul class="pagination justify-content-md-end justify-content-center mb-0">
                    <li class="page-item @(Model.PageNumber == 1 ? "disabled" : string.Empty)">
                        <a asp-area="" asp-controller="Movie" asp-action="Index"
                           asp-route-searchQuery="@Model.SearchQuery" 
                           asp-route-pageNumber="@(Model.PageNumber - 1)" 
                           class="page-link" tabindex="-1">Previous</a>
                    </li>
                    
                    @if (Model.StartPageIndex > 1)
                    {
                        <li class="page-item disabled">
                            <a class="page-link">...</a>
                        </li>
                    }

                    @for (int i = Model.StartPageIndex; i <= endPageIndex; i++)
                    {
                        @if (i > 0)
                        {
                            <li class="page-item @(Model.PageNumber == i ? "active" : string.Empty)">
                                <a asp-area="" asp-controller="Movie" asp-action="Index"
                                   asp-route-searchQuery="@Model.SearchQuery"
                                   asp-route-pageNumber="@i"
                                   class="page-link">@i</a>
                            </li>
                        }
                    }

                    @if (endPageIndex < Model.TotalPages)
                    {
                        <li class="page-item disabled">
                            <a class="page-link">...</a>
                        </li>
                    }

                    <li class="page-item @(Model.PageNumber == Model.TotalPages ? "disabled" : string.Empty)">
                        <a asp-area="" asp-controller="Movie" asp-action="Index"
                           asp-route-searchQuery="@Model.SearchQuery"
                           asp-route-pageNumber="@(Model.PageNumber + 1)"
                           class="page-link">Next</a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
    

    <div class="d-flex flex-column gap-2">
        @foreach (MovieIndexViewModel movie in Model.Movies)
        {
            <div class="card shadow-lg border-0 rounded-3 d-flex flex-row align-items-center p-2"
                 style="height: 140px; max-height: 140px;">

                <img src="@movie.ImageUrl" class="rounded"
                     alt="@movie.Title"
                     style="width: 100px; height: 130px; object-fit: cover;">

                <div class="card-body ms-3 p-2 text-light" style="flex-grow: 1;">
                    <h6 class="fw-bold mb-1 text-dark">@movie.Title</h6>
                    <p class="text-muted mb-0" style="font-size: 0.85rem;">
                        <strong>Genre:</strong> @movie.Genre |
                        <strong>Director:</strong> @movie.Director
                    </p>
                    <p class="text-muted mb-1" style="font-size: 0.85rem;">
                        <strong>Released:</strong> @movie.ReleaseDate
                    </p>
                </div>

                <div class="me-3 d-flex gap-2">
                    <a asp-area="" asp-controller="Movie" asp-action="Details" asp-route-id="@movie.Id" 
                       class="btn btn-primary btn-sm rounded-pill px-4 fw-bold">
                        <i class="bi bi-eye"></i> View Details
                    </a>

                    @if (User?.Identity?.IsAuthenticated == true && movie.IsInUserWatchlist == false)
                    {
                        <a asp-area="" asp-controller="Watchlist" asp-action="Add" asp-route-id="@movie.Id" 
                           class="btn btn-outline-warning btn-sm rounded-pill px-4 fw-bold">
                            <i class="bi bi-bookmark"></i> Add to Watchlist
                        </a>
                    }
                    else
                    {
                        <a asp-area="" asp-controller="Watchlist" asp-action="Add" asp-route-id="@movie.Id"
                           class="btn btn-outline-warning btn-sm rounded-pill px-4 fw-bold flex-shrink-0 invisible">
                            <i class="bi bi-bookmark"></i> Add to Watchlist
                        </a>
                    }
                </div>
            </div>
        }
    </div>
</div>